rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && 
             (resource == null ? request.resource.data.authorUid == request.auth.uid : resource.data.authorUid == request.auth.uid);
    }
    
    function isSuperAdmin() {
      return isAuthenticated() && 
        (
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin') ||
          (request.auth.token.email == "nvardi75@gmail.com" && request.auth.token.email_verified == true)
        );
    }

    function isAdmin() {
      return isAuthenticated() && 
        (
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super_admin']) ||
          (request.auth.token.email == "nvardi75@gmail.com" && request.auth.token.email_verified == true)
        );
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidUser(data) {
      return hasRequiredFields(['uid', 'username', 'role', 'createdAt']) &&
             data.uid is string && data.uid.size() > 0 &&
             data.username is string && data.username.size() > 0 && data.username.size() < 100 &&
             data.role in ['super_admin', 'admin', 'user'] &&
             data.createdAt is number &&
             (!('subscriptionEnd' in data) || data.subscriptionEnd is number) &&
             (!('allowedFeatures' in data) || data.allowedFeatures is map);
    }
    
    function isValidPatient(data) {
      return hasRequiredFields(['id', 'authorUid', 'patientName', 'timestamp']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 50 &&
             data.authorUid is string && data.authorUid.size() > 0 &&
             data.patientName is string && data.patientName.size() > 0 && data.patientName.size() < 150 &&
             data.timestamp is number &&
             (!('age' in data) || (data.age is string && data.age.size() < 20)) &&
             (!('sex' in data) || (data.sex is string && data.sex.size() < 20)) &&
             (!('phone' in data) || (data.phone is string && data.phone.size() < 30)) &&
             (!('email' in data) || (data.email is string && data.email.size() < 100)) &&
             (!('address' in data) || (data.address is string && data.address.size() < 500)) &&
             (!('complaint' in data) || (data.complaint is string && data.complaint.size() < 2000)) &&
             (!('symptoms' in data) || (data.symptoms is string && data.symptoms.size() < 2000)) &&
             (!('selectedSymptoms' in data) || (data.selectedSymptoms is list && data.selectedSymptoms.size() < 100)) &&
             (!('tongue' in data) || data.tongue is map) &&
             (!('pulse' in data) || data.pulse is map) &&
             (!('diagnosis' in data) || data.diagnosis is map) &&
             (!('medicalHistory' in data) || (data.medicalHistory is string && data.medicalHistory.size() < 2000)) &&
             (!('biomedicalDiagnosis' in data) || (data.biomedicalDiagnosis is string && data.biomedicalDiagnosis.size() < 500)) &&
             (!('icd10' in data) || (data.icd10 is string && data.icd10.size() < 50));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      
      allow create: if isOwner(userId) && 
                       isValidUser(request.resource.data) && 
                       request.resource.data.uid == request.auth.uid &&
                       (request.resource.data.role == 'user' || isAdmin());
                       
      allow update: if (isOwner(userId) && 
                       isValidUser(request.resource.data) &&
                       request.resource.data.uid == resource.data.uid &&
                       request.resource.data.createdAt == resource.data.createdAt &&
                       request.resource.data.role == resource.data.role) || isAdmin();
                       
      allow delete: if isAdmin();
    }

    match /patients/{patientId} {
      allow read: if isAuthenticated() && (isDocOwner() || isAdmin());
      allow create: if isAuthenticated() && (isDocOwner() || isAdmin()) && isValidPatient(request.resource.data);
      allow update: if isAuthenticated() && (isDocOwner() || isAdmin()) && isValidPatient(request.resource.data);
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }
  }
}

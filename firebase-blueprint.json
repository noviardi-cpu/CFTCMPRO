{
  "entities": {
    "UserAccount": {
      "title": "UserAccount",
      "description": "A user account for the TCM application.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The Firebase Auth UID of the user."
        },
        "username": {
          "type": "string",
          "description": "The username or display name."
        },
        "role": {
          "type": "string",
          "enum": ["super_admin", "admin", "user"],
          "description": "The role of the user."
        },
        "createdAt": {
          "type": "number",
          "description": "Timestamp of creation."
        },
        "subscriptionEnd": {
          "type": "number",
          "description": "Timestamp of subscription end."
        },
        "allowedFeatures": {
          "type": "object",
          "properties": {
            "chat": { "type": "boolean" },
            "cdss": { "type": "boolean" },
            "atlas": { "type": "boolean" },
            "wuxing": { "type": "boolean" },
            "archive": { "type": "boolean" },
            "invoice": { "type": "boolean" },
            "bmi": { "type": "boolean" }
          }
        }
      },
      "required": ["uid", "username", "role", "createdAt"]
    },
    "SavedPatient": {
      "title": "SavedPatient",
      "description": "A saved patient record including diagnosis.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique ID of the patient record."
        },
        "authorUid": {
          "type": "string",
          "description": "The UID of the user who created this record."
        },
        "patientName": {
          "type": "string"
        },
        "age": {
          "type": "string"
        },
        "sex": {
          "type": "string"
        },
        "phone": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "address": {
          "type": "string"
        },
        "complaint": {
          "type": "string"
        },
        "symptoms": {
          "type": "string"
        },
        "selectedSymptoms": {
          "type": "array",
          "items": { "type": "string" }
        },
        "tongue": {
          "type": "object"
        },
        "pulse": {
          "type": "object"
        },
        "diagnosis": {
          "type": "object"
        },
        "timestamp": {
          "type": "number"
        },
        "medicalHistory": {
          "type": "string"
        },
        "biomedicalDiagnosis": {
          "type": "string"
        },
        "icd10": {
          "type": "string"
        },
        "medications": {
          "type": "string"
        },
        "followUpDate": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      },
      "required": ["id", "authorUid", "patientName", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserAccount" },
      "description": "Stores user profiles."
    },
    "/patients/{patientId}": {
      "schema": { "$ref": "#/entities/SavedPatient" },
      "description": "Stores patient records."
    }
  }
}
